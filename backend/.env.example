# ─── Configuración del servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development

# Orígenes permitidos por CORS (separados por coma, sin espacios)
# En dev puede omitirse y usará los localhost por defecto.
# En prod: FRONTEND_ORIGINS=https://victoriapets.com,https://www.victoriapets.com
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Base de datos MySQL ─────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=victoria_pecuarios

# ─── JWT ─────────────────────────────────────────────────────────
# Generar uno random con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_aleatorio_de_64_caracteres
JWT_EXPIRES_IN=7d

# ─── Email (Brevo / SMTP) ────────────────────────────────────────
EMAIL_USER=tu_email_brevo@dominio.com
EMAIL_PASS=tu_smtp_key_de_brevo
EMAIL_FROM="Victoria Pets <noreply@victoriapets.com>"

# ─── ePayco ──────────────────────────────────────────────────────
EPAYCO_PUBLIC_KEY=tu_public_key
EPAYCO_KEY=tu_private_key
EPAYCO_CUST_ID=tu_customer_id
EPAYCO_TEST=true
